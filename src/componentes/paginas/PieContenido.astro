---
import { pieContenido } from "../../data/siteData";
import AccionesPaginaInterna from "./AccionesPaginaInterna.astro";
---

<main class="internal-page">
  <section class="internal-hero">
    <div class="internal-hero-content">
      <span class="internal-kicker">{pieContenido.subtitulo}</span>
      <h1>{pieContenido.titulo}</h1>
      <AccionesPaginaInterna sectionHref="/" sectionLabel="Inicio" sectionIcon="fa-house" />
    </div>
  </section>

  <section class="pie-page-section">
    <div class="pie-page-container">
      <div class="pie-intro-panel">
        <div class="pie-intro-copy">
          <span>{pieContenido.etiqueta}</span>
          <h2>{pieContenido.encabezado}</h2>
          <p>{pieContenido.introduccion}</p>
        </div>

        <img src={pieContenido.imagenPrincipal} alt={pieContenido.etiqueta} />
      </div>

      <div class="pie-highlight-grid">
        {pieContenido.destacados.map((destacado) => (
          <article class="pie-highlight-card">
            <strong>{destacado.numero}</strong>
            <span>{destacado.texto}</span>
          </article>
        ))}
      </div>

      <div class="pie-info-grid">
        {pieContenido.secciones.map((seccion, index) => (
          <article class:list={["pie-info-block", { "pie-info-block--reverse": index % 2 === 1 }]}>
            <div class="pie-info-media">
              <img src={seccion.imagen} alt={seccion.titulo} />
            </div>

            <div class="pie-info-content">
              <h2>{seccion.titulo}</h2>
              {seccion.texto.map((parrafo) => (
                <p>{parrafo}</p>
              ))}
            </div>
          </article>
        ))}
      </div>

      <div class="pie-support-layout">
        {pieContenido.necesidades.map((grupo) => (
          <article class="pie-support-card">
            <h2>{grupo.titulo}</h2>
            <ul>
              {grupo.items.map((item) => (
                <li>{item}</li>
              ))}
            </ul>
          </article>
        ))}
      </div>

      <section class="pie-objectives-panel">
        <div class="pie-staff-heading">
          <span>Objetivos Específicos</span>
          <h2>Trabajo del Programa de Integración Escolar</h2>
        </div>

        <div class="pie-objectives-list">
          {pieContenido.objetivosEspecificos.map((objetivo, index) => (
            <article>
              <span>{String(index + 1).padStart(2, "0")}</span>
              <p>{objetivo}</p>
            </article>
          ))}
        </div>
      </section>

      <section class="pie-team-section">
        <div class="pie-staff-heading">
          <span>Equipo PIE</span>
          <h2>{pieContenido.equipoTitulo}</h2>
        </div>

        <div class="pie-team-table">
          {pieContenido.personal.map((persona) => (
            <article>
              <h3>{persona.nombre}</h3>
              <span>{persona.cargo}</span>
              <strong>{persona.horas} hrs</strong>
            </article>
          ))}
        </div>
      </section>
    </div>
  </section>
</main>
