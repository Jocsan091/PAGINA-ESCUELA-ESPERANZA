---
import {
  directivas,
  seccionesInstitucionales,
  talleres
} from "../../data/siteData";
import { rutas } from "../../lib/rutas";
---

<section class="home-directories-section">
  <div class="home-directories-container">
    <div class="home-section-heading">
      <span>Comunidad</span>
      <h2>Directivas</h2>
    </div>

    <div class="home-directories-grid">
      {directivas.map((directiva) => (
        <a href={rutas.directivas} class="home-directory-card">
          <h3>{directiva}</h3>
          <i class="fa-solid fa-arrow-right"></i>
        </a>
      ))}
    </div>
  </div>
</section>

<section class="home-sections-section">
  <div class="home-sections-container">
    <div class="home-section-heading">
      <span>Escuela</span>
      <h2>Informacion institucional</h2>
    </div>

    <div class="institutional-list">
      {seccionesInstitucionales.map((seccion) => (
        <a href={`${rutas.institucional}#${seccion.id}`} class="institutional-row">
          <h3>{seccion.titulo}</h3>
          <i class="fa-solid fa-arrow-right"></i>
        </a>
      ))}
    </div>
  </div>
</section>

<section class="home-workshops-section">
  <div class="home-workshops-container">
    <div class="home-section-heading home-section-heading--light">
      <span>Talleres</span>
      <h2>Talleres escolares</h2>
    </div>

    <div class="home-workshops-strip">
      {talleres.map((taller) => (
        <a href={rutas.talleres} class="home-workshop-pill">{taller}</a>
      ))}
    </div>
  </div>
</section>
